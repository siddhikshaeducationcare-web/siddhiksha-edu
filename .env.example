# =============================================
# Siddhiksha Education Care — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# =============================================

# ---- Supabase ----
# Get these from: https://supabase.com/dashboard → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...YOUR_SERVICE_ROLE_KEY

# ---- Resend (Email) ----
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# ---- Institution Email ----
# This email receives admission notifications
INSTITUTION_EMAIL=info@siddhikshaedu.com

# ---- Admin (optional — for NextAuth or custom auth) ----
ADMIN_EMAIL=admin@siddhikshaedu.com
ADMIN_PASSWORD=your_secure_password_here
NEXTAUTH_SECRET=your_random_secret_string_here
NEXTAUTH_URL=http://localhost:3000

# ---- Site URL ----
NEXT_PUBLIC_SITE_URL=https://siddhikshaedu.com
